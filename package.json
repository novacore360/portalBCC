{
  "name": "bcc-portal",
  "version": "1.0.0",
  "scripts": {
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "start": "cd server && node index.js",
    "dev-server": "cd server && nodemon index.js",
    "dev-client": "cd client && npm start"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
